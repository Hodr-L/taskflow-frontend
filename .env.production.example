# 前端生产环境配置

# API配置
VITE_API_URL=https://api.taskflow.example.com
VITE_API_TIMEOUT=10000
VITE_API_VERSION=v1

# 应用配置
VITE_APP_NAME=TaskFlow
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
VITE_APP_DEBUG=false

# 功能开关
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_FILE_UPLOAD=true
VITE_FEATURE_REAL_TIME=true
VITE_FEATURE_ANALYTICS=true

# 认证配置
VITE_AUTH_TOKEN_KEY=taskflow_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=taskflow_refresh_token
VITE_AUTH_USER_KEY=taskflow_user
VITE_AUTH_TOKEN_EXPIRY=86400  # 24小时

# WebSocket配置
VITE_WS_URL=wss://api.taskflow.example.com/ws
VITE_WS_RECONNECT_INTERVAL=5000
VITE_WS_MAX_RECONNECT_ATTEMPTS=10

# 文件上传配置
VITE_UPLOAD_MAX_SIZE=10485760  # 10MB
VITE_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
VITE_UPLOAD_CHUNK_SIZE=1048576  # 1MB

# 缓存配置
VITE_CACHE_ENABLED=true
VITE_CACHE_PREFIX=taskflow_
VITE_CACHE_TTL=3600000  # 1小时

# 性能配置
VITE_LAZY_LOAD_ENABLED=true
VITE_PREFETCH_ENABLED=true
VITE_COMPRESSION_ENABLED=true

# 监控配置
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=
VITE_HOTJAR_ID=

# 主题配置
VITE_THEME=light  # light, dark, auto
VITE_PRIMARY_COLOR=#3B82F6
VITE_SECONDARY_COLOR=#10B981

# 国际化配置
VITE_DEFAULT_LOCALE=zh-CN
VITE_FALLBACK_LOCALE=en-US
VITE_SUPPORTED_LOCALES=zh-CN,en-US

# 构建配置
VITE_SOURCE_MAP=false
VITE_MINIFY=true
VITE_CHUNK_SIZE_WARNING_LIMIT=500

# 安全配置
VITE_CSP_ENABLED=true
VITE_HSTS_ENABLED=true
VITE_XSS_PROTECTION_ENABLED=true

# PWA配置
VITE_PWA_ENABLED=true
VITE_PWA_NAME=TaskFlow
VITE_PWA_SHORT_NAME=TaskFlow
VITE_PWA_THEME_COLOR=#3B82F6
VITE_PWA_BACKGROUND_COLOR=#FFFFFF