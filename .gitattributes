# 设置所有文本文件使用CRLF行尾
* text=auto eol=crlf

# 确保这些文件始终被视为文本文件
*.vue text
*.ts text
*.js text
*.css text
*.html text
*.json text
*.md text
*.yaml text
*.yml text
*.txt text
*.bat text eol=crlf
*.sh text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary